/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
  X-Frame-Options: DENY
  Permissions-Policy: accelerometer=(), autoplay=(), camera=(), geolocation=(), gyroscope=(), magnetometer=(), microphone=(), payment=(), usb=()
  Cross-Origin-Opener-Policy: same-origin
  Cross-Origin-Resource-Policy: same-origin
  Cross-Origin-Embedder-Policy: require-corp
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload
  Content-Security-Policy: default-src 'self'; base-uri 'self'; object-src 'none'; frame-ancestors 'none'; form-action 'self'; img-src 'self' data: https:; font-src 'self' data: https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; script-src 'self' 'unsafe-inline' 'unsafe-eval' https://cdn.jsdelivr.net; connect-src 'self' https://*.muonnoi.org https://api.muonnoi.org https://mail.iai.one; manifest-src 'self'; worker-src 'self'; upgrade-insecure-requests
  Cache-Control: no-store

/assets/*
  Cache-Control: public, max-age=300

/assets/brand/*
  Cache-Control: public, max-age=86400

/manifest.json
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=86400

/robots.txt
  Cache-Control: public, max-age=86400

/favicon.ico
  Cache-Control: public, max-age=86400

/favicon.svg
  Cache-Control: public, max-age=86400

/og.png
  Cache-Control: public, max-age=86400

/og.svg
  Cache-Control: public, max-age=86400

/app*
  Cache-Control: no-store
