---
import Layout from '../components/Layout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import RiskBanner from '../components/RiskBanner.astro';

const title = 'Quy trình đầu tư · Đầu Tư Muôn Nơi';
const description = '6 bước quy trình quan tâm đầu tư vào hệ sinh thái Muôn Nơi.';
---

<Layout title={title} description={description} canonical="https://dautu.muonnoi.org/process/">
  <Navigation />

  <div class="bg-brand-900 text-white py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-3xl font-bold">Quy trình quan tâm đầu tư</h1>
      <p class="text-brand-100 mt-2">Minh bạch từng bước — không giao dịch ngầm.</p>
    </div>
  </div>

  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="space-y-8">
      <div class="flex items-start gap-5">
        <span class="flex-shrink-0 w-12 h-12 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold text-lg">1</span>
        <div>
          <h3 class="text-xl font-bold text-gray-900">Xem thông tin dự án</h3>
          <p class="text-gray-700 mt-1">Tìm hiểu kỹ dự án quan tâm: thị trường, sản phẩm, đội ngũ, rủi ro. Đọc hồ sơ đầu tư đầy đủ trước khi quyết định.</p>
        </div>
      </div>
      <div class="flex items-start gap-5">
        <span class="flex-shrink-0 w-12 h-12 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold text-lg">2</span>
        <div>
          <h3 class="text-xl font-bold text-gray-900">Đọc cảnh báo rủi ro</h3>
          <p class="text-gray-700 mt-1">Hiểu rõ rủi ro đầu tư giai đoạn đầu: có thể mất toàn bộ vốn, không có thanh khoản, không cam kết lợi nhuận.</p>
        </div>
      </div>
      <div class="flex items-start gap-5">
        <span class="flex-shrink-0 w-12 h-12 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold text-lg">3</span>
        <div>
          <h3 class="text-xl font-bold text-gray-900">Gửi form quan tâm</h3>
          <p class="text-gray-700 mt-1">Điền thông tin nhà đầu tư trên trang Quan tâm. Không bắt buộc đăng nhập. Không chuyển tiền ở bước này.</p>
        </div>
      </div>
      <div class="flex items-start gap-5">
        <span class="flex-shrink-0 w-12 h-12 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold text-lg">4</span>
        <div>
          <h3 class="text-xl font-bold text-gray-900">Đội phụ trách kiểm tra</h3>
          <p class="text-gray-700 mt-1">Review profile, quốc gia cư trú, tư cách nhà đầu tư. Có thể yêu cầu bổ sung tài liệu (KYC).</p>
        </div>
      </div>
      <div class="flex items-start gap-5">
        <span class="flex-shrink-0 w-12 h-12 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold text-lg">5</span>
        <div>
          <h3 class="text-xl font-bold text-gray-900">Vòng trao đổi riêng</h3>
          <p class="text-gray-700 mt-1">Nếu hồ sơ phù hợp, mời vào deal room — nơi chia sẻ tài liệu chi tiết hơn (có password protection).</p>
        </div>
      </div>
      <div class="flex items-start gap-5">
        <span class="flex-shrink-0 w-12 h-12 bg-brand-600 text-white rounded-full flex items-center justify-center font-bold text-lg">6</span>
        <div>
          <h3 class="text-xl font-bold text-gray-900">Giao dịch chính thức</h3>
          <p class="text-gray-700 mt-1">Chỉ sau khi hồ sơ pháp lý hoàn chỉnh + thanh toán chính thức qua pay.iai.one (không chuyển khoản trực tiếp).</p>
        </div>
      </div>
    </div>

    <div class="mt-12 p-6 bg-gray-50 rounded-xl border border-gray-200">
      <h3 class="font-bold text-gray-900 mb-3">Lưu ý quan trọng</h3>
      <ul class="list-disc list-inside space-y-2 text-gray-700">
        <li>Form quan tâm public không phải giao dịch đầu tư.</li>
        <li>Không chuyển tiền trực tiếp cho bất kỳ cá nhân nào tự xưng là đại diện Muôn Nơi.</li>
        <li>Chỉ thanh toán qua pay.iai.one với invoice chính thức.</li>
        <li>Deal room mở theo lời mời riêng, không public.</li>
      </ul>
    </div>
  </div>

  <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pb-12">
    <RiskBanner />
  </div>

  <Footer />
</Layout>
