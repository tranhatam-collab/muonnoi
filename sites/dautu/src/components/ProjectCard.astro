---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;

const statusColors: Record<string, string> = {
  'Concept': 'bg-gray-100 text-gray-700',
  'Draft Plan': 'bg-blue-100 text-blue-700',
  'Founder Review Ready': 'bg-yellow-100 text-yellow-700',
  'Build Started (63/100)': 'bg-orange-100 text-orange-700',
  'Investment Interest Open': 'bg-green-100 text-green-700',
};
---

<article class="bg-white rounded-xl shadow-sm border border-gray-200 p-6 hover:shadow-md transition flex flex-col h-full">
  <div class="flex items-center justify-between mb-3">
    <span class="text-xs font-semibold uppercase tracking-wide text-brand-600">{project.category}</span>
    <span class={`inline-block px-2 py-1 rounded-full text-xs font-medium ${statusColors[project.status] || 'bg-gray-100 text-gray-700'}`}>
      {project.status}
    </span>
  </div>
  <h3 class="text-xl font-bold text-gray-900 mb-2">{project.name}</h3>
  <p class="text-sm text-gray-600 mb-3 italic">{project.tagline}</p>
  <p class="text-gray-700 text-sm leading-relaxed mb-4 flex-grow">{project.description}</p>
  <div class="grid grid-cols-2 gap-3 text-sm mb-4">
    <div>
      <span class="text-gray-500 block text-xs">TAM</span>
      <span class="font-semibold text-gray-900">{project.tam}</span>
    </div>
    <div>
      <span class="text-gray-500 block text-xs">Nhu cầu vốn</span>
      <span class="font-semibold text-gray-900">{project.fundingNeed}</span>
    </div>
  </div>
  <a
    href={`/projects/${project.slug}/`}
    class="w-full text-center px-4 py-2 bg-brand-600 text-white rounded-lg font-medium hover:bg-brand-700 transition mt-auto"
  >
    Xem hồ sơ
  </a>
</article>
