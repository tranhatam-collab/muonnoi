---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Đường Muôn Nơi — Đang chuẩn bị pilot">
	<main style="max-width: 800px; margin: 0 auto; padding: 4rem 1.5rem; text-align: center;">
		<h1 style="font-size: 2.5rem; margin-bottom: 1rem; color: #2d5a3d;">
			Đường Muôn Nơi
		</h1>
		<p style="font-size: 1.25rem; color: #555; margin-bottom: 2rem;">
			Trải nghiệm Đà Lạt có chủ đích
		</p>
		<p style="color: #777; margin-bottom: 3rem;">
			Đang chuẩn bị pilot — tháng 8/2026
		</p>
		<div style="background: #e8f5e9; padding: 2rem; border-radius: 8px; margin-bottom: 2rem;">
			<p style="margin-bottom: 1rem;">
				<strong>Sống thật, đi thật, gặp người thật, ghi lại bằng chứng thật</strong>
			</p>
			<p style="font-size: 0.9rem; color: #666;">
				Pilot nội bộ, invite-only. Không đăng ký công khai ở thời điểm này.
			</p>
		</div>
		<footer style="margin-top: 4rem; font-size: 0.85rem; color: #999;">
			<p>Muonnoi.org — Life Quest OS</p>
			<p style="margin-top: 0.5rem;">Pilot v0.1 · Đà Lạt · 2026</p>
		</footer>
	</main>
</Layout>
