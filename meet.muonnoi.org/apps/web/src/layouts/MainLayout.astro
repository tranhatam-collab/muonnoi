---
interface Props {
  title?: string;
  description?: string;
}

const { title = 'Meet Muon Noi — Meaningful Connections', description = 'Real people. Real intentions. Real trust.' } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content="https://meet.muonnoi.org" />
  </head>
  <body class="min-h-screen bg-white text-slate-900 dark:bg-slate-950 dark:text-slate-100">
    <slot />
  </body>
</html>
