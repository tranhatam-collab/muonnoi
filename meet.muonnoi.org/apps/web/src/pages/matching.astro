---
import MainLayout from '@layouts/MainLayout.astro';
import Header from '@components/Header';
import Footer from '@components/Footer';
---

<MainLayout title="Matching — Meet Muon Noi">
  <Header client:load />
  <main class="px-4 py-12">
    <div class="mx-auto max-w-2xl text-center">
      <h1 class="mb-3 text-2xl font-bold text-slate-900 dark:text-white">Daily matches</h1>
      <p class="mb-8 text-slate-600 dark:text-slate-400">
        A small, curated list of people who share your values. Refresh daily at 9 AM.
      </p>
      <div class="rounded-2xl border border-slate-200 bg-slate-50 p-8 dark:border-slate-800 dark:bg-slate-900">
        <p class="text-sm text-slate-500 dark:text-slate-400">Matches appear here when you are verified.</p>
        <a
          href="/login"
          class="mt-4 inline-block rounded-full bg-teal-700 px-6 py-2.5 text-sm font-medium text-white transition-colors hover:bg-teal-800 dark:bg-teal-600 dark:hover:bg-teal-500"
        >
          Log in to see matches
        </a>
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>
