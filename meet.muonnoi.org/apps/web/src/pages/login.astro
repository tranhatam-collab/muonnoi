---
import MainLayout from '@layouts/MainLayout.astro';
import Header from '@components/Header';
import Footer from '@components/Footer';
import LoginForm from '@components/LoginForm';
---

<MainLayout title="Log in — Meet Muon Noi">
  <Header client:load />
  <main class="flex min-h-[60vh] items-center justify-center px-4 py-12">
    <div class="w-full max-w-sm">
      <h1 class="mb-2 text-center text-2xl font-bold text-slate-900 dark:text-white">Welcome back</h1>
      <p class="mb-6 text-center text-sm text-slate-500 dark:text-slate-400">
        Enter your email and we will send you a secure magic link.
      </p>
      <LoginForm client:load />
    </div>
  </main>
  <Footer />
</MainLayout>
