---
import MainLayout from '@layouts/MainLayout.astro';
import Header from '@components/Header';
import Footer from '@components/Footer';
import LoginForm from '@components/LoginForm';
---

<MainLayout title="Đăng nhập — Kết Nối Muôn Nơi" description="Đăng nhập vào Kết Nối Muôn Nơi">
  <Header client:load />
  <main class="flex min-h-[70vh] items-center justify-center px-4">
    <div class="w-full max-w-md">
      <div class="mb-8 text-center">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Đăng nhập</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Nhập email để nhận magic link hoặc sử dụng passkey
        </p>
      </div>
      <LoginForm client:load />
      <div class="mt-6 text-center text-sm text-slate-500 dark:text-slate-500">
        Chưa có tài khoản?{' '}
        <a href="/register" class="font-medium text-teal-700 hover:underline dark:text-teal-400">
          Đăng ký ngay
        </a>
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>
