---
import MainLayout from '../layouts/MainLayout.astro';
---

<MainLayout title="Xác minh đăng nhập — Kết Nối Muôn Nơi" noindex={true}>
  <main class="flex min-h-screen items-center justify-center px-4">
    <div class="w-full max-w-md rounded-2xl border border-slate-200 bg-white p-8 shadow-sm dark:border-slate-800 dark:bg-slate-900">
      <div id="verify-state" class="text-center">
        <div class="mb-4 flex justify-center">
          <div class="h-8 w-8 animate-spin rounded-full border-2 border-teal-600 border-t-transparent" />
        </div>
        <h1 class="mb-2 text-lg font-semibold text-slate-900 dark:text-white">Đang xác minh...</h1>
        <p class="text-sm text-slate-600 dark:text-slate-400">Vui lòng đợi trong giây lát.</p>
      </div>
    </div>
  </main>
</MainLayout>

<script>
  import { verifyMagicLink } from '../lib/auth';

  async function run() {
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');
    const state = document.getElementById('verify-state')!;

    if (!token) {
      state.innerHTML = `
        <div class="text-red-600 dark:text-red-400">
          <p class="font-semibold">Link không hợp lệ</p>
          <p class="text-sm mt-1">Không tìm thấy token xác minh.</p>
          <a href="/login" class="mt-4 inline-block text-teal-600 hover:underline dark:text-teal-400">Quay lại đăng nhập</a>
        </div>
      `;
      return;
    }

    const result = await verifyMagicLink(token);

    if (result.success && result.session) {
      state.innerHTML = `
        <div class="text-teal-700 dark:text-teal-400">
          <p class="font-semibold">Đăng nhập thành công!</p>
          <p class="text-sm mt-1">Chuyển hướng đến trang chính...</p>
        </div>
      `;
      setTimeout(() => {
        window.location.href = '/matching';
      }, 1000);
    } else {
      state.innerHTML = `
        <div class="text-red-600 dark:text-red-400">
          <p class="font-semibold">Xác minh thất bại</p>
          <p class="text-sm mt-1">${result.error || 'Token hết hạn hoặc không hợp lệ.'}</p>
          <a href="/login" class="mt-4 inline-block text-teal-600 hover:underline dark:text-teal-400">Quay lại đăng nhập</a>
        </div>
      `;
    }
  }

  run();
</script>
