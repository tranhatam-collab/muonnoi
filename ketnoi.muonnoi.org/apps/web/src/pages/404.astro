---
import MainLayout from '@layouts/MainLayout.astro';
import Header from '@components/Header';
import Footer from '@components/Footer';
---

<MainLayout title="Không tìm thấy — Kết Nối Muôn Nơi" description="Trang không tồn tại">
  <Header client:load />
  <main class="flex min-h-[70vh] items-center justify-center px-4">
    <div class="text-center">
      <h1 class="mb-2 text-6xl font-extrabold text-teal-700 dark:text-teal-400">404</h1>
      <h2 class="mb-4 text-2xl font-bold text-slate-900 dark:text-white">Trang không tồn tại</h2>
      <p class="mb-8 text-slate-600 dark:text-slate-400">
        Có vẻ như bạn đã đi lạc. Hãy quay lại trang chủ nhé.
      </p>
      <a
        href="/"
        class="inline-flex items-center gap-2 rounded-full bg-teal-700 px-6 py-3 text-sm font-semibold text-white transition-colors hover:bg-teal-800 dark:bg-teal-600 dark:hover:bg-teal-500"
      >
        Về trang chủ
      </a>
    </div>
  </main>
  <Footer />
</MainLayout>
