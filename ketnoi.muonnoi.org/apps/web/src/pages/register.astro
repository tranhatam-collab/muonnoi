---
import MainLayout from '@layouts/MainLayout.astro';
import Header from '@components/Header';
import Footer from '@components/Footer';
import RegisterForm from '@components/RegisterForm';
---

<MainLayout title="Đăng ký — Kết Nối Muôn Nơi" description="Tạo tài khoản Kết Nối Muôn Nơi">
  <Header client:load />
  <main class="flex min-h-[70vh] items-center justify-center px-4">
    <div class="w-full max-w-lg">
      <div class="mb-6 text-center">
        <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Tạo tài khoản</h1>
        <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
          Bước 1: Thông tin cơ bản. Bạn phải từ 18 tuổi trở lên.
        </p>
      </div>
      <RegisterForm client:load />
      <div class="mt-6 text-center text-sm text-slate-500 dark:text-slate-500">
        Đã có tài khoản?{' '}
        <a href="/login" class="font-medium text-teal-700 hover:underline dark:text-teal-400">
          Đăng nhập
        </a>
      </div>
    </div>
  </main>
  <Footer />
</MainLayout>
