---
import MainLayout from '@layouts/MainLayout.astro';
import Header from '@components/Header';
import Footer from '@components/Footer';
import MatchingPage from '@components/MatchingPage';
---

<MainLayout title="Khám phá — Kết Nối Muôn Nơi" description="Những gợi ý kết nối phù hợp với bạn">
  <Header client:load />
  <main class="min-h-[70vh] px-4 py-8">
    <div class="mx-auto max-w-2xl">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="text-2xl font-bold text-slate-900 dark:text-white">Gợi ý hôm nay</h1>
          <p class="text-sm text-slate-600 dark:text-slate-400">5–12 gợi ý chất lượng được chọn riêng cho bạn</p>
        </div>
      </div>
      <MatchingPage client:load />
    </div>
  </main>
  <Footer />
</MainLayout>
