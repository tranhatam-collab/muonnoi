{
  "name": "ketnoi-muonnoi-web",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "lint": "eslint . --ext .js,.jsx,.ts,.tsx,.astro",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "test:unit:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "audit": "node scripts/audit.mjs",
    "audit:security": "node scripts/audit-security.mjs",
    "audit:i18n": "node scripts/audit-i18n.mjs",
    "audit:a11y": "node scripts/audit-a11y.mjs",
    "qa": "npm run lint && npm run typecheck && npm run test:unit && npm run audit",
    "loop:dev": "node scripts/dev-loop.mjs",
    "health-check": "node scripts/health-check.mjs",
    "precommit": "npm run lint && npm run typecheck && npm run audit:security",
    "format": "prettier --write ."
  },
  "dependencies": {
    "@astrojs/react": "^4.0.0",
    "@astrojs/tailwind": "^6.0.0",
    "@tanstack/react-query": "^5.0.0",
    "astro": "^5.0.0",
    "clsx": "^2.1.0",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-intl": "^7.0.0",
    "tailwind-merge": "^2.6.0",
    "tailwindcss": "^3.4.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "@vitejs/plugin-react": "^4.3.0",
    "eslint": "^9.0.0",
    "eslint-plugin-astro": "^1.3.0",
    "eslint-plugin-react": "^7.37.0",
    "jsdom": "^25.0.0",
    "playwright": "^1.49.0",
    "prettier": "^3.3.0",
    "prettier-plugin-astro": "^0.14.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  }
}
